# ─── ShapersOS Environment Variables ───
# Copy this file to .env.local and fill in your values.
# On Netlify, set these in Site Settings → Environment Variables.

# Anthropic (leave empty to use mock fallback)
ANTHROPIC_API_KEY=

# Clerk Auth (get keys from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/

# Notion Integration Token (https://www.notion.so/my-integrations)
NOTION_API_KEY=

# Notion Database IDs (32-char hex from the database URL)
NOTION_NORTH_STAR_DB=
NOTION_BRAND_GUIDELINES_DB=
NOTION_SALES_MECHANISM_DB=
NOTION_SKILLS_REGISTRY_DB=
